<?xml version="1.0" encoding="UTF-8"?>
<schemalist>

  <enum id="org.gnome.shell.extensions.gnome-panel.mode">
    <value nick="classic"  value="0"/>
    <value nick="floating" value="1"/>
  </enum>

  <enum id="org.gnome.shell.extensions.gnome-panel.theme">
    <value nick="cyberpunk"       value="0"/>
    <value nick="dracula"         value="1"/>
    <value nick="ubuntu-yaru"     value="2"/>
    <value nick="gruvbox"         value="3"/>
    <value nick="nordic"          value="4"/>
    <value nick="solid-dark"      value="5"/>
    <value nick="solid-light"     value="6"/>
    <value nick="gnome-dark"      value="7"/>
  </enum>

  <schema id="org.gnome.shell.extensions.gnome-panel"
          path="/org/gnome/shell/extensions/gnome-panel/">

    <key name="mode" enum="org.gnome.shell.extensions.gnome-panel.mode">
      <default>"classic"</default>
      <summary>Tryb paska</summary>
      <description>Classic – pasek przyklejony do krawędzi, okna go omijają. Floating – pasek z marginesem.</description>
    </key>

    <key name="auto-hide" type="b">
      <default>false</default>
      <summary>Auto-ukrywanie (tylko floating)</summary>
      <description>Pasek znika gdy okno nachodzi na jego obszar i pojawia się przy najechaniu kursorem na dolną krawędź.</description>
    </key>

    <key name="prevent-method" type="s">
      <default>'strut'</default>
      <summary>Metoda zapobiegania znikaniu paska (Wayland)</summary>
      <description>'strut' – rezerwuje 4 piksele (lekka, stabilna). 'disable-unredirect' – wyłącza Direct Scanout (brak przerwy, większe obciążenie GPU).</description>
    </key>

    <key name="theme" enum="org.gnome.shell.extensions.gnome-panel.theme">
      <default>"cyberpunk"</default>
      <summary>Motyw paska</summary>
      <description>Wygląd tła paska zadań: cyberpunk, dracula, ubuntu-yaru, gruvbox, nordic, solid-dark, solid-light, gnome-dark.</description>
    </key>

  </schema>
</schemalist>