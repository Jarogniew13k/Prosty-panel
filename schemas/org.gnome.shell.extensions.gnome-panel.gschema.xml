<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.gnome-panel"
          path="/org/gnome/shell/extensions/gnome-panel/">

    <!-- ── Tryb paska ─────────────────────────────────────────────────── -->
    <key name="mode" type="s">
      <choices>
        <choice value="classic"/>
        <choice value="floating"/>
      </choices>
      <default>'classic'</default>
      <summary>Panel mode</summary>
      <description>
        'classic'  — pasek przyklejony do dolnej krawędzi ekranu.
        'floating' — pasek z marginesem; tapeta widoczna pod spodem.
      </description>
    </key>

    <!-- ── Auto-ukrywanie (tylko tryb floating) ───────────────────────── -->
    <key name="auto-hide" type="b">
      <default>false</default>
      <summary>Auto-hide panel</summary>
      <description>
        Gdy włączone, pasek chowa się po przesunięciu kursora poza jego obszar.
        Działa wyłącznie w trybie 'floating'.
      </description>
    </key>

    <!-- ── Motyw wizualny ─────────────────────────────────────────────── -->
    <key name="theme" type="s">
      <choices>
        <choice value="cyberpunk"/>
        <choice value="dracula"/>
        <choice value="ubuntu-yaru"/>
        <choice value="gruvbox"/>
        <choice value="nordic"/>
        <choice value="solid-dark"/>
        <choice value="solid-light"/>
        <choice value="gnome-dark"/>
      </choices>
      <default>'gnome-dark'</default>
      <summary>Visual theme</summary>
      <description>
        Motyw kolorystyczny paska zadań. Zmiana jest natychmiastowa —
        nie wymaga przeładowania rozszerzenia.
      </description>
    </key>

  </schema>
</schemalist>
